{
  "version": 2,
  "builds": [
    {
      "src": "./index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api-docs/(.*)",
      "dest": "/index.js"
    }
  ],
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/api/swagger.json"
    },
    {
      "source": "/api-docs/:path*",
      "destination": "/swagger-ui/index.html"
    },
    {
      "source": "/api-docs",
      "destination": "/swagger-ui/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api-docs/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}